#. translators: %1$s and %2$s: discovery-document field names, shown as code
#: admin/admin-page.php:267
#, php-format
msgid ""
"Allows KaliCart Global to index this catalog and include it in federated "
"agent search. Published in the discovery document as %1$s and %2$s. Read-"
"only: Global never writes to your store."
msgstr ""
"Permet à KaliCart Global d’indexer ce catalogue et de l’inclure dans la "
"recherche fédérée pour agents. Publié dans le document de découverte sous "
"%1$s et %2$s. Lecture seule : Global n’écrit jamais dans votre boutique."

#: admin/admin-page.php:275
msgid "Checkout sessions"
msgstr "Sessions de paiement"

#: admin/admin-page.php:275
msgid "optional"
msgstr "facultatif"

#. translators: %s: the POST /checkout/session endpoint, shown as code
#: admin/admin-page.php:276
#, php-format
