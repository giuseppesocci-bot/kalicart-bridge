#. Plugin Name of the plugin
#: kalicart-bridge.php
msgid "KaliCart Bridge – Product Feed for ChatGPT & AI Agents"
msgstr "KaliCart Bridge – Flux produits pour ChatGPT et agents IA"

#. Plugin URI of the plugin
#: kalicart-bridge.php
msgid "https://bridge.kalicart.com"
msgstr "https://bridge.kalicart.com"

#. Description of the plugin
#: kalicart-bridge.php
msgid "Makes your WooCommerce catalog machine-readable and agent-accessible. Exposes normalized product data via REST API — no LLM, no external service, no cloud dependency."
msgstr "Rend votre catalogue WooCommerce lisible par les machines et accessible aux agents. Expose des données produit normalisées via une API REST — pas de LLM, pas de service externe, pas de dépendance cloud."

#. Author of the plugin
#: kalicart-bridge.php
msgid "KaliCart"
msgstr "KaliCart"

#. Author URI of the plugin
