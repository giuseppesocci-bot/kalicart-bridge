msgid "Daily ChatGPT feed refresh"
msgstr "Aggiornamento giornaliero del feed ChatGPT"

#. translators: %d: invalid rows
#: includes/class-acp-feed.php:665
msgid "Enabled"
msgstr "Attivo"

#. translators: %d: invalid rows
#: includes/class-acp-feed.php:665
msgid "Manual only"
msgstr "Solo manuale"

#. translators: %d: invalid rows
#: includes/class-acp-feed.php:665
msgid "Regenerates the validated ChatGPT feed file once per day; delivery to OpenAI is a separate step."
msgstr "Rigenera il file del feed ChatGPT validato una volta al giorno; la consegna a OpenAI è un passaggio separato."

#. translators: %d: invalid rows
#: includes/class-acp-feed.php:665
msgid "The ChatGPT feed changes only when generated manually and may become outdated after catalog changes."
msgstr "Il feed ChatGPT cambia solo quando viene generato manualmente e può diventare obsoleto dopo modifiche al catalogo."

#: includes/class-acp-feed.php:666
msgid "OpenAI feed delivery"
msgstr "Consegna del feed a OpenAI"

#: includes/class-acp-feed.php:666
msgid "Connected"
msgstr "Connesso"

#: includes/class-acp-feed.php:666
msgid "Application required"
msgstr "Candidatura richiesta"

#: includes/class-acp-feed.php:666
msgid "This plugin currently prepares the file. OpenAI approves the merchant and assigns SFTP or API delivery credentials."
msgstr "Al momento il plugin prepara il file. OpenAI approva il merchant e assegna le credenziali di consegna SFTP o API."

#: includes/class-acp-feed.php:670
msgid "Last validated ChatGPT feed snapshot:"
msgstr "Ultimo snapshot validato del feed ChatGPT:"

#: includes/class-acp-feed.php:670
msgid "conformant rows from"
msgstr "righe conformi da"

#: includes/class-acp-feed.php:670
msgid "products."
