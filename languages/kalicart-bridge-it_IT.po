#. translators: %s: the POST /checkout/session endpoint, shown as code
#: admin/admin-page.php:292
#, php-format
msgid ""
"Enables %s — agent creates a session, merchant gets a checkout URL, human "
"completes payment on WooCommerce. No OAuth, no PII, no payment on the agent "
"side."
msgstr ""
"Abilita %s — l’agente crea una sessione, il merchant ottiene un URL di "
"checkout, l’umano completa il pagamento su WooCommerce. Niente OAuth, niente "
"PII, nessun pagamento lato agente."

