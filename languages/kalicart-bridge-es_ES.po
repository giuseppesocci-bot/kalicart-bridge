#. Plugin Name of the plugin
#: kalicart-bridge.php
msgid "KaliCart Bridge – Product Feed for ChatGPT & AI Agents"
msgstr "KaliCart Bridge – Feed de productos para ChatGPT y agentes de IA"

#. Plugin URI of the plugin
#: kalicart-bridge.php
msgid "https://bridge.kalicart.com"
msgstr "https://bridge.kalicart.com"

#. Description of the plugin
#: kalicart-bridge.php
msgid ""
"Makes your WooCommerce catalog machine-readable and agent-accessible. "
"Exposes normalized product data via REST API — no LLM, no external service, "
"no cloud dependency."
msgstr ""
"Hace que tu catálogo de WooCommerce sea legible por máquinas y accesible "
"para agentes. Expone datos de producto normalizados mediante una API REST — "
"sin LLM, sin servicio externo, sin dependencia de la nube."

#. Author of the plugin
#: kalicart-bridge.php
msgid "KaliCart"
msgstr "KaliCart"

#. Author URI of the plugin
#: kalicart-bridge.php
msgid "https://kalicart.com"
msgstr "https://kalicart.com"

#: admin/admin-page.php:25
