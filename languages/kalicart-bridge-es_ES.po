#. Plugin Name of the plugin
#: kalicart-bridge.php
msgid "KaliCart Bridge – Product Feed for ChatGPT & AI Agents"
msgstr "KaliCart Bridge – Feed de productos para ChatGPT y agentes de IA"

#. Plugin URI of the plugin
#: kalicart-bridge.php
msgid "https://bridge.kalicart.com"
msgstr "https://bridge.kalicart.com"

#. Description of the plugin
#: kalicart-bridge.php
msgid "Makes your WooCommerce catalog machine-readable and agent-accessible. Exposes normalized product data via REST API — no LLM, no external service, no cloud dependency."
msgstr "Hace que tu catálogo de WooCommerce sea legible por máquinas y accesible para agentes. Expone datos de producto normalizados mediante una API REST — sin LLM, sin servicio externo, sin dependencia de la nube."

#. Author of the plugin
#: kalicart-bridge.php
msgid "KaliCart"
msgstr "KaliCart"

#. Author URI of the plugin
#: kalicart-bridge.php
msgid "https://kalicart.com"
msgstr "https://kalicart.com"

#: admin/admin-page.php:25
msgid "Agent-readable catalog"
msgstr "Catálogo legible por agentes"

#: admin/admin-page.php:33
msgid "Great choice! Your catalog is going global."
msgstr "¡Excelente elección! Tu catálogo se vuelve global."

#: admin/admin-page.php:34
msgid "Increase your catalog's visibility"
msgstr "Aumenta la visibilidad de tu catálogo"

#. translators: %1$s: opening link tag to privacy notice, %2$s: closing link tag
#: admin/admin-page.php:40
#, php-format
msgid "AI assistants can now find your products across the KaliCart global network. Only public catalog data is shared, and you can deactivate it anytime. %1$sSee what is shared%2$s."
msgstr "Los asistentes de IA ya pueden encontrar tus productos en la red global de KaliCart. Solo se comparten los datos públicos del catálogo y puedes desactivarlo cuando quieras. %1$sDescubre qué se comparte%2$s."

#. translators: %1$s: opening link tag to privacy notice, %2$s: closing link tag
#: admin/admin-page.php:47
#, php-format
msgid "Activate the Federated Catalog for free: your products join a global network where AI assistants can find them. It only takes one click, and you can deactivate it anytime. %1$sSee what is shared%2$s."
msgstr "Activa gratis el Catálogo Federado: tus productos entran en una red global donde los asistentes de IA pueden encontrarlos. Solo necesitas un clic y puedes desactivarlo cuando quieras. %1$sDescubre qué se comparte%2$s."

